---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if page.title_zh != blank or page.title_en != blank %}
        <span data-lang="zh">{{ page.title_zh | default: page.title }}</span>
        <span data-lang="en">{{ page.title_en | default: page.title }}</span>
      {% else %}
        {{ page.title }}
      {% endif %}
    </h1>
    <p class="post-description">
      {% if page.description_zh != blank or page.description_en != blank %}
        <span data-lang="zh">{{ page.description_zh | default: page.description }}</span>
        <span data-lang="en">{{ page.description_en | default: page.description }}</span>
      {% else %}
        {{ page.description }}
      {% endif %}
    </p>
  </header>

  <article>
    {{ content }}
  </article>

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
